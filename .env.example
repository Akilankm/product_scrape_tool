# Product scraping agent runtime settings
PCA_OUTPUT_ROOT=data/scraped
PCA_SCRAPE_HEADLESS=true
PCA_SCRAPE_TIMEOUT=35
PCA_SCRAPE_WAIT_UNTIL=domcontentloaded


# Evidence Recovery Mode
# The scraper does NOT perform search. These are optional local files you can pass
# through CLI/notebook when search/discovery already produced AI Mode snippets or
# indexed evidence. They are tagged as A-axis evidence in the artifact.
# CLI example:
#   --upstream-ai-evidence-file evidence/ai_mode.txt \
#   --candidate-snippet "Indexed snippet..." \
#   --search-evidence-json evidence/search_evidence.json
PCA_EVIDENCE_RECOVERY_MODE=true

# Agentic same-URL evidence-building loop
PCA_AGENTIC_ENABLED=true
PCA_AGENTIC_MAX_ITERATIONS=2
PCA_STRICT_PRODUCT_ONLY=true
PCA_WRITE_RAW_DEBUG=false
PCA_SCAN_FULL_PAGE=false

# URL-first geo/access/proxy handling
# Direct access from India/Azure may be blocked for some country-specific retailer pages.
# The agent will never mark a blocked page as "product absent"; it records access_status instead.
# Proxy orchestration is built in. The actual proxy endpoint/credentials remain external
# because they are secrets/network resources. If PCA_PROXY_URL_<COUNTRY> or PCA_PROXY_URL
# is configured, the agent can retry the SAME product URL through that route when blocked.
PCA_GEO_RETRY_ON_ACCESS_BLOCK=true
PCA_PROXY_URL=
PCA_PROXY_URL_CZ=
PCA_PROXY_URL_CO=
PCA_PROXY_URL_MX=
PCA_ACCEPT_LANGUAGE=
PCA_ACCEPT_LANGUAGE_CZ=
PCA_ACCEPT_LANGUAGE_CO=
PCA_ACCEPT_LANGUAGE_MX=

# Set false only for degraded deterministic fallback mode.
PCA_LLM_ENABLED=true
PCA_LLM_VISION_ENABLED=true
PCA_LLM_VISION_MAX_IMAGES=12
PCA_LLM_VISION_DETAIL=low
PCA_RELEVANCE_BATCH=8
PCA_DOWNLOAD_CONCURRENCY=8
PCA_VISION_CONCURRENCY=5

# Azure OpenAI / corporate gateway
PCA_LLM_API_KEY=
PCA_LLM_API_VERSION=2024-10-21
PCA_LLM_ENDPOINT=https://your-azure-openai-endpoint
PCA_LLM_DEPLOYMENT=gpt-4o
PCA_LLM_CONSUMER_ID=
PCA_LLM_MAX_TOKENS=8192
PCA_LLM_TEMPERATURE=0.0
PCA_LLM_CONNECT_TIMEOUT=15
PCA_LLM_READ_TIMEOUT=120
PCA_LLM_MAX_RETRIES=4
