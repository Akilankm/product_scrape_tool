# Product scraping agent runtime settings
PCA_OUTPUT_ROOT=data/scraped
PCA_SCRAPE_HEADLESS=true
PCA_SCRAPE_TIMEOUT=35
PCA_SCRAPE_WAIT_UNTIL=domcontentloaded

# Agentic same-URL evidence-building loop
PCA_AGENTIC_ENABLED=true
PCA_AGENTIC_MAX_ITERATIONS=2
PCA_STRICT_PRODUCT_ONLY=true
PCA_WRITE_RAW_DEBUG=false
PCA_SCAN_FULL_PAGE=false

# Set false only for degraded deterministic fallback mode.
PCA_LLM_ENABLED=true
PCA_LLM_VISION_ENABLED=true
PCA_LLM_VISION_MAX_IMAGES=12
PCA_LLM_VISION_DETAIL=low
PCA_RELEVANCE_BATCH=8
PCA_DOWNLOAD_CONCURRENCY=8
PCA_VISION_CONCURRENCY=5

# Azure OpenAI / corporate gateway
PCA_LLM_API_KEY=
PCA_LLM_API_VERSION=2024-10-21
PCA_LLM_ENDPOINT=https://your-azure-openai-endpoint
PCA_LLM_DEPLOYMENT=gpt-4o
PCA_LLM_CONSUMER_ID=
PCA_LLM_MAX_TOKENS=8192
PCA_LLM_TEMPERATURE=0.0
PCA_LLM_CONNECT_TIMEOUT=15
PCA_LLM_READ_TIMEOUT=120
PCA_LLM_MAX_RETRIES=4
